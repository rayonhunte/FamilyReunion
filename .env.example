VITE_FIREBASE_API_KEY=your-public-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
# Must match Firebase Console → Storage (often .appspot.com for older projects, .firebasestorage.app for newer)
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FUNCTIONS_URL=/api
VITE_BOOTSTRAP_ADMIN_EMAIL=admin@hunteinvest.com
